# Time Messenger Configuration

# URL of your Time Messenger instance (required)
TIME_URL=https://your-instance.time-messenger.ru

# ===== Authentication Method 1: Personal Access Token (recommended) =====
# Create it in: Time Messenger -> Profile -> Account Settings -> Security -> Personal Access Tokens
TIME_TOKEN=your_personal_access_token_here

# ===== Authentication Method 2: Login + Password =====
# Session token will be obtained automatically via /api/v4/users/login.
# Session tokens may expire. Personal Access Tokens are preferred.
# TIME_LOGIN_ID=your_username_or_email
# TIME_PASSWORD=your_password

# ===== Authentication Method 3: OAuth2 (not supported for MCP) =====
# OAuth2 Authorization Code flow requires a browser redirect,
# which is not suitable for a CLI-based MCP server.
# If you need OAuth2, use the Personal Access Token method instead.
# To use OAuth2 in your own web app, see:
# https://docs.time-messenger.ru/integrations/oauth2_service_provider

# ===== Security hardening (this fork) =====
# Write/state-changing tools (send_message, follow_thread, unfollow_thread,
# mark_thread_read) are DISABLED by default to limit prompt-injection blast
# radius. Set this to true/1/yes/on to enable them.
# TIME_ALLOW_WRITE=false

# Per-request network timeout in milliseconds (default: 30000).
# TIME_REQUEST_TIMEOUT_MS=30000
